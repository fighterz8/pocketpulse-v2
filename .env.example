# PostgreSQL connection string (required for Drizzle and connect-pg-simple)
DATABASE_URL=postgresql://user:password@localhost:5432/pocketpulse

# Session signing secret (use a long random string in production)
SESSION_SECRET=change-me-in-production

# development | production | test
NODE_ENV=development

# Listen port for `npm run dev` and production (`npm start`). Replit sets PORT=5000.
# PORT=5000

# Optional: target for `npm run dev:vite` proxy when API runs on a non-default port
# API_PORT=5001

# Browser origin in dev (same as `npm run dev` URL)
APP_ORIGIN=http://localhost:5000
